#!/bin/bash
exec uvx --from 'ipython==9.14.1' --with 'numpy==2.2.6,polars==1.41.2,pandas==2.3.3,scipy==1.17.1' -- ipython -i --no-banner -c "$(cat <<'EOF'
from math import *
import numpy as np
import polars as pl
import random
import scipy
from pathlib import Path

def logit10(x):
    return float(scipy.special.logit(x) / log(10))

def expit10(x):
    return float(scipy.special.expit(x * log(10)))
EOF
)"
